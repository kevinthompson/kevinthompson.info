---
import { type CollectionEntry, getCollection } from 'astro:content'
import PageLayout from '@layouts/PageLayout.astro'
import Container from '@components/Container.astro'
import FormattedDate from '@components/FormattedDate.astro'
import { readingTime } from '@lib/utils'
import BackToPrev from '@components/BackToPrev.astro'
import Link from '@components/Link.astro'

export async function getStaticPaths() {
  const games = (await getCollection('games'))
    .filter((game) => !game.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  return games.map((game) => ({
    params: { slug: game.slug },
    props: game,
  }))
}
type Props = CollectionEntry<'games'>

const game = Astro.props
const { Content } = await game.render()
---

<PageLayout title={game.data.title} description={game.data.description}>
  <Container>
    <div class="animate">
      <BackToPrev href="/games">Back to games</BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={game.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(game.body)}
        </div>
      </div>
      <div class="animate text-2xl font-semibold text-black dark:text-white">
        {game.data.title}
      </div>
      {
        (game.data.demoURL || game.data.repoURL) && (
          <nav class="animate flex gap-1">
            {game.data.demoURL && (
              <Link href={game.data.demoURL} external>
                play
              </Link>
            )}
            {game.data.demoURL && game.data.repoURL && <span>/</span>}
            {game.data.repoURL && (
              <Link href={game.data.repoURL} external>
                repo
              </Link>
            )}
          </nav>
        )
      }
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>
